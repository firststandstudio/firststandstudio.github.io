---
// Date: 4/20/2026 | Developer: Yahia Saad | License: First Stand Studio. All rights reserved.
import { navigation } from "../../data/navigation";
import { siteConfig } from "../../data/site";
import { getDictionary } from "../../i18n/copy";
import {
  defaultLocale,
  localeMeta,
  localizePath,
  supportedLocales,
  swapLocale,
  type SupportedLocale
} from "../../i18n/config";

interface Props {
  locale?: SupportedLocale;
}

const { locale = defaultLocale } = Astro.props;
const dict = getDictionary(locale);
const menuLabels = {
  en: "Menu",
  ar: "القائمة",
  fr: "Menu",
  ru: "Меню",
  ja: "メニュー"
} as const;
const primaryNavigationLabels = {
  en: "Primary",
  ar: "التنقل الرئيسي",
  fr: "Navigation principale",
  ru: "Основная навигация",
  ja: "主要ナビゲーション"
} as const;

const pathname = Astro.url.pathname;
const localeLinks = supportedLocales.map((code) => ({
  code,
  label: localeMeta[code].nativeLabel,
  shortLabel: localeMeta[code].shortLabel,
  href: swapLocale(pathname, code)
}));

function isActive(href: string) {
  const localizedHref = localizePath(href, locale);

  if (localizedHref === "/") {
    return pathname === "/";
  }

  return pathname.startsWith(localizedHref);
}
---

<header class="siteHeader" data-site-header transition:name="site-header">
  <div class="shellWide frame">
    <a class="brand" href={localizePath("/", locale)} aria-label={siteConfig.studioName}>
      <span class="brandMark" aria-hidden="true"></span>
      <span class="brandText">
        <strong>{siteConfig.studioName}</strong>
        <small>{siteConfig.owner}</small>
      </span>
    </a>

    <button
      class="menuToggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-navigation"
      data-menu-toggle
    >
      {menuLabels[locale]}
    </button>

    <nav class="navPanel" id="site-navigation" aria-label={primaryNavigationLabels[locale]} data-nav-panel>
      <ul>
        {navigation.map((item) => (
          <li>
            <a href={localizePath(item.href, locale)} aria-current={isActive(item.href) ? "page" : undefined}>
              {dict.navigation[item.label.toLowerCase() as keyof typeof dict.navigation]}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <details class="localePicker">
      <summary aria-label={dict.common.languageLabel}>
        <span>{localeMeta[locale].shortLabel}</span>
      </summary>
      <ul data-locale-panel>
        {localeLinks.map((link) => (
          <li>
            <a href={link.href} aria-current={link.code === locale ? "true" : undefined}>
              <span>{link.shortLabel}</span>
              <small>{link.label}</small>
            </a>
          </li>
        ))}
      </ul>
    </details>
  </div>
</header>

<style>
  .siteHeader {
    position: sticky;
    top: 0;
    z-index: 40;
    padding-top: 0.82rem;
    pointer-events: none;
  }

  .frame {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 0.9rem;
    padding: 0.58rem 0.9rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background: rgba(255, 248, 239, 0);
    backdrop-filter: blur(0);
    box-shadow: 0 12px 32px rgba(78, 58, 30, 0);
    pointer-events: auto;
    transition:
      background 280ms ease,
      border-color 280ms ease,
      backdrop-filter 280ms ease,
      box-shadow 280ms ease;
  }

  .siteHeader[data-scrolled="true"] .frame {
    border-color: var(--line);
    background: rgba(252, 246, 238, 0.88);
    backdrop-filter: blur(14px);
    box-shadow: 0 14px 28px rgba(86, 67, 42, 0.08);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .brandMark {
    position: relative;
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, rgba(245, 222, 181, 0.96), rgba(173, 128, 61, 0.96) 72%);
    box-shadow: 0 0 0 1px rgba(117, 85, 36, 0.1), 0 0 18px rgba(187, 145, 83, 0.24);
  }

  .brandMark::after {
    content: "";
    position: absolute;
    inset: -0.34rem;
    border: 1px solid rgba(187, 145, 83, 0.18);
    border-radius: 50%;
    opacity: 0.32;
  }

  .brandText {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .brandText strong,
  .brandText small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .brandText strong {
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .brandText small {
    color: var(--text-muted);
    font-size: 0.64rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .menuToggle {
    display: none;
    justify-self: end;
    padding: 0.65rem 0.95rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 248, 239, 0.74);
    color: var(--text);
  }

  .navPanel ul {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
    list-style: none;
  }

  .localePicker {
    position: relative;
  }

  .localePicker summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.25rem;
    min-height: 2.45rem;
    padding: 0 0.8rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 248, 239, 0.76);
    color: var(--text);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    list-style: none;
    cursor: pointer;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .localePicker summary::-webkit-details-marker {
    display: none;
  }

  .localePicker summary:hover,
  .localePicker summary:focus-visible {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    background: rgba(255, 249, 241, 0.96);
  }

  .localePicker ul {
    position: absolute;
    top: calc(100% + 0.65rem);
    right: 0;
    display: grid;
    gap: 0.45rem;
    min-width: 11rem;
    padding: 0.7rem;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.72)),
      var(--bg-panel-strong);
    box-shadow: 0 16px 40px rgba(86, 67, 42, 0.1);
    list-style: none;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px) scale(0.98);
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .localePicker[open] ul {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .localePicker li {
    min-width: 0;
  }

  .localePicker a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.68rem 0.8rem;
    border: 1px solid transparent;
    border-radius: 0.95rem;
    color: var(--text-soft);
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease,
      color 220ms ease;
  }

  .localePicker a span {
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .localePicker a small {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .localePicker a:hover,
  .localePicker a:focus-visible,
  .localePicker a[aria-current="true"] {
    transform: translateY(-1px);
    border-color: var(--line);
    background: rgba(255, 248, 239, 0.84);
    color: var(--text);
  }

  .navPanel a {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 2.45rem;
    padding: 0 0.88rem;
    border-radius: 999px;
    color: var(--text-soft);
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition:
      color 220ms ease,
      background 220ms ease,
      transform 220ms ease;
  }

  .navPanel a::after {
    content: "";
    position: absolute;
    inset-inline: 1rem;
    bottom: 0.62rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--green-bright), transparent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 240ms ease;
  }

  .navPanel a:hover,
  .navPanel a:focus-visible {
    color: var(--text);
    background: rgba(255, 248, 239, 0.82);
    transform: translateY(-1px);
  }

  .navPanel a:hover::after,
  .navPanel a:focus-visible::after,
  .navPanel a[aria-current="page"]::after {
    transform: scaleX(1);
  }

  .navPanel a[aria-current="page"] {
    color: var(--text);
    background: var(--green-soft);
  }

  @media (max-width: 820px) {
    .frame {
      grid-template-columns: auto auto auto;
    }

    .menuToggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .navPanel {
      grid-column: 1 / -1;
      display: none;
    }

    :global(html.nav-open) .navPanel {
      display: block;
    }

    .navPanel ul {
      display: grid;
      gap: 0.45rem;
      width: 100%;
      padding-top: 0.4rem;
    }

    .navPanel a {
      justify-content: space-between;
      width: 100%;
      border: 1px solid var(--line);
      background: rgba(255, 248, 239, 0.78);
    }

    .navPanel a::after {
      bottom: 0.8rem;
    }

    .localePicker {
      justify-self: end;
    }

    .localePicker ul {
      right: 0;
      left: auto;
      min-width: 10rem;
    }
  }
</style>
