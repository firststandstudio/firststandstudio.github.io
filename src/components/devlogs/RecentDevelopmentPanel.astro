---
// Date: 4/20/2026 | Developer: Yahia Saad | License: First Stand Studio. All rights reserved.
import { formatDate } from "../../lib/date";
import { defaultLocale, type SupportedLocale } from "../../i18n/config";
import { getDictionary } from "../../i18n/copy";

interface DevelopmentRow {
  message: string;
  committedAt: string;
  relativeTime?: string;
  href?: string;
  hash?: string;
}

interface Props {
  title?: string;
  eyebrow?: string;
  items: DevelopmentRow[];
  compact?: boolean;
  locale?: SupportedLocale;
}

const {
  items,
  compact = false,
  locale = defaultLocale
} = Astro.props;
const dict = getDictionary(locale);
const title = Astro.props.title ?? dict.common.recentDevelopment;
const eyebrow = Astro.props.eyebrow ?? dict.common.githubAware;
---

<aside class:list={["panel", compact && "compact", "surfaceCard"]} data-reveal>
  <p class="eyebrow">{eyebrow}</p>
  <h3>{title}</h3>

  <ol>
    {items.map((item) => (
      <li>
        {item.href ? (
          <a href={item.href} target="_blank" rel="noreferrer">
            <span class="message">{item.message}</span>
            <span class="meta">
              {item.hash && <span>{item.hash}</span>}
              <span>{item.relativeTime ?? formatDate(item.committedAt, locale)}</span>
            </span>
          </a>
        ) : (
          <div class="staticItem">
            <span class="message">{item.message}</span>
            <span class="meta">
              {item.hash && <span>{item.hash}</span>}
              <span>{item.relativeTime ?? formatDate(item.committedAt, locale)}</span>
            </span>
          </div>
        )}
      </li>
    ))}
  </ol>
</aside>

<style>
  .panel {
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
  }

  .compact {
    padding: 1.25rem;
  }

  h3 {
    font-size: clamp(1.6rem, 2.8vw, 2rem);
  }

  ol {
    display: grid;
    gap: 0.85rem;
    list-style: none;
  }

  li {
    min-width: 0;
  }

  a,
  .staticItem {
    display: grid;
    gap: 0.45rem;
    padding: 0.95rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: rgba(255, 249, 241, 0.76);
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  a:hover,
  a:focus-visible {
    transform: translateY(-2px);
    border-color: var(--line-strong);
    background: rgba(255, 247, 236, 0.98);
  }

  .message {
    min-width: 0;
    color: var(--text);
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    color: var(--text-muted);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
</style>
