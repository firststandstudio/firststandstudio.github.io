---
// Date: 4/20/2026 | Developer: Yahia Saad | License: First Stand Studio. All rights reserved.
interface Props {
  eyebrow: string;
  manifesto: string;
  aboutText: string;
  founderLabel: string;
  founderValue: string;
  originLabel: string;
  originValue: string;
  positionLabel: string;
  positionValue: string;
}

const {
  eyebrow,
  manifesto,
  aboutText,
  founderLabel,
  founderValue,
  originLabel,
  originValue,
  positionLabel,
  positionValue
} = Astro.props;
---

<section class="aboutSurface surfaceCard" data-reveal>
  <div class="statement">
    <p class="eyebrow">{eyebrow}</p>
    <h2>{manifesto}</h2>
  </div>

  <div class="details">
    <p>{aboutText}</p>
    <dl>
      <div>
        <dt>{founderLabel}</dt>
        <dd>{founderValue}</dd>
      </div>
      <div>
        <dt>{originLabel}</dt>
        <dd>{originValue}</dd>
      </div>
      <div>
        <dt>{positionLabel}</dt>
        <dd>{positionValue}</dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .aboutSurface {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(1.6rem, 4vw, 3rem);
    align-items: start;
    padding: clamp(1.6rem, 4vw, 2.9rem);
    border-radius: clamp(1.9rem, 4vw, 2.4rem);
  }

  .statement {
    display: grid;
    gap: 0.8rem;
    align-content: start;
    min-width: 0;
  }

  h2 {
    min-width: 0;
    font-size: clamp(2.4rem, 4vw, 3.7rem);
    line-height: 1;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .details {
    display: grid;
    gap: 1.4rem;
    min-width: 0;
    color: var(--text-soft);
  }

  .details p,
  dd {
    min-width: 0;
    overflow-wrap: anywhere;
    line-height: 1.75;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  dl div {
    display: grid;
    gap: 0.35rem;
    align-content: start;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  dt {
    color: var(--text-muted);
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    color: var(--text);
    font-size: 1.02rem;
  }

  @media (max-width: 840px) {
    .aboutSurface {
      grid-template-columns: 1fr;
    }

    dl {
      grid-template-columns: 1fr;
    }
  }
</style>
