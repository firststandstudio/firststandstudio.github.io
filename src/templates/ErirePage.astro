---
// Date: 4/20/2026 | Developer: Yahia Saad | License: First Stand Studio. All rights reserved.
import DevlogCard from "../components/devlogs/DevlogCard.astro";
import ParticleField from "../components/motion/ParticleField.astro";
import RecentDevelopmentPanel from "../components/devlogs/RecentDevelopmentPanel.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { projectMap } from "../data/projects";
import { getDictionary } from "../i18n/copy";
import { getLocalizedDevlogFromEntry } from "../i18n/devlogs";
import { getErirePageCopy } from "../i18n/erire";
import { defaultLocale, type SupportedLocale } from "../i18n/config";
import { getLocalizedProject } from "../i18n/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSortedDevlogs } from "../lib/content";
import { getRecentCommits } from "../lib/github";

interface Props {
  locale?: SupportedLocale;
}

const { locale = defaultLocale } = Astro.props;
const dict = getDictionary(locale);
const erirePage = getErirePageCopy(locale);
const baseProject = projectMap.get("erire");

if (!baseProject) {
  throw new Error("Erire project configuration is missing.");
}

const project = getLocalizedProject(baseProject, locale);
const relatedDevlogs = await getSortedDevlogs(project.slug);
const recentDevelopment = await getRecentCommits(project.github, 2, locale);
const insightFacts = project.facts.slice(2, 4);
const primaryFacts = project.facts.slice(0, 4);

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: project.title,
  description: project.description,
  creator: {
    "@type": "Person",
    name: "Yahia Saad"
  }
};
---

<BaseLayout
  title={project.title}
  description={project.description}
  image={project.logo}
  favicon={project.favicon.src}
  theme="erire"
  structuredData={projectSchema}
  locale={locale}
>
  <section class="section pageIntro projectHero">
    <ParticleField density={11} tone="erire" clusterX={0.68} clusterY={0.2} />
    <div class="shellWide heroGrid">
      <div class="copy">
        <p class="eyebrow" data-reveal>{dict.common.projectPage}</p>
        <h1 class="pageTitle" data-reveal transition:name="page-title" style="--reveal-delay: 80ms;">
          {project.title}
        </h1>
        <p class="lede" data-reveal style="--reveal-delay: 160ms;">{project.description}</p>

        <div class="heroMeta" data-reveal style="--reveal-delay: 240ms;">
          <span class="pill">• {project.status}</span>
          <span>{project.type}</span>
        </div>
      </div>

      <div class="poster surfaceCard" data-reveal style="--reveal-delay: 180ms;">
        <div class="posterGlow" aria-hidden="true"></div>
        <img
          src={project.logo.src}
          alt={`${project.title} logo`}
          width={project.logo.width}
          height={project.logo.height}
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shellWide summaryGrid">
      <article class="summary surfaceCard" data-reveal>
        <p class="eyebrow">{erirePage.summaryEyebrow}</p>
        <h2>{erirePage.summaryTitle}</h2>
        <p>{project.atmosphere}</p>
      </article>

      <RecentDevelopmentPanel
        items={recentDevelopment}
        compact={true}
        locale={locale}
        title={dict.common.recentDevelopment}
        eyebrow={dict.common.githubAware}
      />
    </div>
  </section>

  <section class="section mediaStripSection">
    <div class="shellWide">
      <SectionHeading
        eyebrow={erirePage.visualEyebrow}
        title={erirePage.visualTitle}
        copy={erirePage.visualCopy}
      />

      <div class="mediaStrip">
        <article class="mediaCard mark surfaceCard" data-reveal>
          <img
            src={project.logo.src}
            alt={`${project.title} logo on atmospheric project panel`}
            width={project.logo.width}
            height={project.logo.height}
            loading="lazy"
            decoding="async"
          />
        </article>

        {insightFacts.map((fact, index) => (
          <article class="mediaCard insight surfaceCard" data-reveal style={`--reveal-delay:${(index + 1) * 90}ms`}>
            <p class="label">{fact.label}</p>
            <p>{fact.value}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shellWide">
      <SectionHeading eyebrow={erirePage.factsEyebrow} title={erirePage.factsTitle} />
      <div class="facts">
        {primaryFacts.map((fact, index) => (
          <article class="fact surfaceCard" data-reveal style={`--reveal-delay:${index * 90}ms`}>
            <p class="label">{fact.label}</p>
            <p class="value">{fact.value}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shellWide">
      <SectionHeading
        eyebrow={erirePage.relatedEyebrow}
        title={erirePage.relatedTitle}
        copy={erirePage.relatedCopy}
      />

      {relatedDevlogs.length > 0 ? (
        <div class="devlogs">
          {relatedDevlogs.map((entry, index) => {
            const localizedEntry = getLocalizedDevlogFromEntry(entry, locale);

            return (
              <div style={`--reveal-delay:${index * 90}ms`}>
                <DevlogCard
                  entry={entry}
                  locale={locale}
                  title={localizedEntry.title}
                  description={localizedEntry.description}
                  tags={localizedEntry.tags}
                  ctaLabel={dict.common.readEntry}
                />
              </div>
            );
          })}
        </div>
      ) : (
        <div class="empty surfaceCard" data-reveal>
          <p>{erirePage.emptyRelated}</p>
        </div>
      )}
    </div>
  </section>

  <section class="section">
    <div class="shellWide linksGrid">
      <article class="surfaceCard linksCard" data-reveal>
        <p class="eyebrow">{dict.common.usefulLinks}</p>
        {project.links.length > 0 ? (
          <div class="projectLinks">
            {project.links.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
            ))}
          </div>
        ) : (
          <p class="muted">{dict.common.noProjectLinks}</p>
        )}
      </article>

      <article class="surfaceCard stateCard" data-reveal style="--reveal-delay: 120ms;">
        <p class="eyebrow">{erirePage.stateEyebrow}</p>
        <h2>• {project.status}</h2>
        <p>{erirePage.stateCopy}</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .projectHero {
    position: relative;
    overflow: clip;
  }

  .heroGrid,
  .summaryGrid,
  .linksGrid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.72fr);
    gap: clamp(1.5rem, 3vw, 2rem);
    align-items: center;
  }

  .copy {
    display: grid;
    gap: 1rem;
    min-width: 0;
    max-width: 44rem;
  }

  .heroMeta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    color: var(--text-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .copy :is(h1, p, span),
  .summary :is(h2, p),
  .mediaCard :is(p),
  .fact :is(p),
  .stateCard :is(h2, p) {
    min-width: 0;
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .poster {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 26rem;
    padding: clamp(1.5rem, 4vw, 2.8rem);
    border-radius: clamp(1.8rem, 4vw, 2.4rem);
    overflow: clip;
  }

  .poster::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(140deg, rgba(255, 255, 255, 0.58), transparent 34%),
      radial-gradient(circle at center, var(--green-soft), transparent 62%);
  }

  .posterGlow {
    position: absolute;
    inset: 12%;
    border-radius: 2rem;
    background: radial-gradient(circle, rgba(170, 120, 64, 0.18), transparent 62%);
    filter: blur(18px);
  }

  .poster img {
    position: relative;
    z-index: 1;
    width: min(26rem, 72%);
    filter: drop-shadow(0 20px 46px rgba(0, 0, 0, 0.28));
  }

  .summary,
  .linksCard,
  .stateCard {
    display: grid;
    gap: 1rem;
    min-width: 0;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
  }

  .summary h2,
  .stateCard h2 {
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.02;
  }

  .summary p:last-child,
  .stateCard p:last-child {
    color: var(--text-soft);
  }

  .mediaStripSection {
    padding-top: 0;
  }

  .mediaStrip {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 0.72fr)) minmax(0, 1.2fr);
    gap: 1rem;
    align-items: stretch;
  }

  .mediaCard {
    border-radius: var(--radius-lg);
    overflow: clip;
  }

  .mark {
    display: grid;
    place-items: center;
    min-height: 13.5rem;
    padding: 1.5rem;
    background:
      radial-gradient(circle at center, rgba(170, 120, 64, 0.14), transparent 56%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.42)),
      var(--bg-panel-strong);
  }

  .mark img {
    width: min(18rem, 68%);
  }

  .insight {
    display: grid;
    align-content: center;
    min-height: 13.5rem;
    padding: 1.35rem;
    gap: 0.85rem;
  }

  .label {
    color: var(--green-bright);
    font-size: 0.76rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .insight p:last-child {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.55;
    text-wrap: balance;
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .fact {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
    padding: 1.2rem;
    border-radius: var(--radius-lg);
  }

  .value {
    font-size: 1.1rem;
    color: var(--text);
  }

  .devlogs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .empty {
    padding: 1.4rem;
    border-radius: var(--radius-lg);
  }

  .projectLinks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .projectLinks a {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0 1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 248, 239, 0.82);
    transition:
      transform 200ms ease,
      border-color 200ms ease,
      background 200ms ease;
  }

  .projectLinks a:hover,
  .projectLinks a:focus-visible {
    transform: translateY(-2px);
    border-color: var(--line-strong);
    background: rgba(255, 247, 236, 1);
  }

  @media (max-width: 1080px) {
    .heroGrid,
    .summaryGrid,
    .linksGrid,
    .mediaStrip {
      grid-template-columns: 1fr;
    }

    .facts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .facts,
    .devlogs {
      grid-template-columns: 1fr;
    }
  }
</style>
