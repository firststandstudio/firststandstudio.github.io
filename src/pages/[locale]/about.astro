import { getSecondaryLocales, type SupportedLocale } from "../../i18n/config";
import AboutPage from "../../templates/AboutPage.astro";

export function getStaticPaths() {
  return getSecondaryLocales().map((locale) => ({
    params: { locale }
  }));
}

const { locale } = Astro.params as { locale: SupportedLocale };
---

<AboutPage locale={locale} />
